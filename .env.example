# Gemini API Key (Get one for free at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets Spreadsheet ID (Found in the Google Sheet URL: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Path to Google Service Account JSON file (or use GOOGLE_SERVICE_ACCOUNT_JSON below)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Optional: Raw JSON string of service account key (useful for GitHub Actions secrets)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}


